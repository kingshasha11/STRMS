<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20" style="-fx-padding: 60; -fx-background-color: #f4f6f8;" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/21" fx:controller="src.controller.LoginController">

    <Label style="-fx-font-size: 24; -fx-font-weight: bold;" text="Login" textAlignment="CENTER" />

    <VBox maxWidth="320" spacing="8">
        <Label text="Email" />
        <TextField fx:id="emailField" promptText="votre@email.com" />

        <Label text="Mot de passe" />
        <PasswordField fx:id="passwordField" promptText="••••••••" />

        <Label fx:id="errorLabel" style="-fx-text-fill: red;" visible="false" />

        <Button maxWidth="Infinity" onAction="#handleLogin" style="-fx-background-color: #3B6D11; -fx-text-fill: white;" text="Se connecter" />
    </VBox>
</VBox>
